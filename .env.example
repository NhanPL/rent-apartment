# Backend
PORT=4000
# Supabase/PostgreSQL connection string format:
# postgresql://<user>:<password>@<db-host>.supabase.co:5432/<database>
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_POOL_MAX=10
JWT_ACCESS_SECRET=<your_access_secret>
JWT_REFRESH_SECRET=<your_refresh_secret>
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
# Optional bank defaults for QR payment request
DEFAULT_BANK_CODE=<bank_code>
DEFAULT_BANK_ACCOUNT_NO=<bank_account_number>
DEFAULT_BANK_ACCOUNT_NAME=<account_name>

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:5000/api
