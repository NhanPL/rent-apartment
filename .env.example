# Backend
PORT=4000
# Supabase/PostgreSQL connection string format:
# postgresql://<user>:<password>@<db-host>.supabase.co:5432/<database>
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_POOL_MAX=10
JWT_ACCESS_SECRET=<your_access_secret>
JWT_REFRESH_SECRET=<your_refresh_secret>
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:4000/api
# Optional bank defaults for QR payment request
DEFAULT_BANK_CODE=<bank_code>
DEFAULT_BANK_ACCOUNT_NO=<bank_account_number>
DEFAULT_BANK_ACCOUNT_NAME=<account_name>
CLOUDINARY_CLOUD_NAME=<cloudinary_cloud_name>
CLOUDINARY_API_KEY=<cloudinary_api_key>
CLOUDINARY_API_SECRET=<cloudinary_api_secret>
CLOUDINARY_UPLOAD_ROOT_FOLDER=rent-apartment
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment-result
VNPAY_IPN_URL=http://localhost:4000/api/payments/vnpay/ipn
VNPAY_VERSION=2.1.0
VNPAY_LOCALE=vn
VNPAY_ORDER_TYPE=other
VNPAY_EXPIRE_MINUTES=15

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:4000/api
